{
    "layer": "top",
    "position": "top",
    "height": 32,
    "margin-top": 6,
    "margin-left": 10,
    "margin-right": 10,
    "spacing": 0,

    "modules-left": ["ext/workspaces"],
    "modules-center": ["cpu", "memory"],
    "modules-right": ["custom/language", "clock", "battery", "network"],

    "ext/workspaces": {
        "format": "{name}",
        "all-outputs": true,
        "active-only": false,
        "on-scroll-up": "",
        "on-scroll-down": "",
        "on-click": "activate",
        "on-click-right": "deactivate",
        "sort-by-id": true
    },

    "cpu": {
        "interval": 2,
        "format": " {usage}%",
        "tooltip": true,
        "tooltip-format": "CPU: {usage}%"
    },

    "memory": {
        "interval": 5,
        "format": "󰾆 {used:0.1f}G",
        "tooltip": true,
        "tooltip-format": "RAM: {used:0.1f}G / {total:0.1f}G ({percentage}%)"
    },

    "clock": {
        "format": "{:%H:%M  %d.%m.%Y}",
        "format-alt": "{:%A, %d %B %Y}",
        "tooltip-format": "{:%Y-%m-%d %H:%M:%S}",
        "interval": 1
    },

    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-icons": ["󰁺", "󰁻", "󰁼", "󰁽", "󰁾", "󰁿", "󰂀", "󰂁", "󰂂", "󰁹"],
        "tooltip": true,
        "tooltip-format": "{timeTo} {capacity}%"
    },

    "network": {
        "format-wifi": "󰤨 {essid}",
        "format-ethernet": "󰈀 {ifname}",
        "format-disconnected": "󰤭 Offline",
        "tooltip-format": "{ifname} via {gwaddr}",
        "interval": 5
    },

    "custom/language": {
        "exec": "mmsg get keyboardlayout 2>/dev/null | sed -n 's/.*\"layout\":\"\\([^\"]*\\)\".*/\\1/p' | sed 's/English (US)/us/; s/English (UK)/gb/; s/Russian/ru/; s/English/en/; s/\\(.*\\) (.*)/\\1/; s/ //g' || setxkbmap -query 2>/dev/null | awk -F': ' '/layout/{print $2}' || echo \"$XKB_DEFAULT_LAYOUT\"",
        "interval": 1,
        "format": "󰌌 {}",
        "tooltip": false
    }
}
